# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║         looni-neutron_builder  •  Containerfile.neutron                    ║
# ║   Ubuntu 24.04 •  proton-wine + DXVK + VKD3D-Proton build environment    ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
#
# Build (run once from the looni-neutron_builder directory):
#
#   podman build \
#       --build-arg BUILD_USER="$(whoami)" \
#       --build-arg BUILD_UID="$(id -u)" \
#       --build-arg BUILD_GID="$(id -g)" \
#       -t looni-neutron_builder \
#       -f Containerfile.neutron .
#
# Run a build:
#
#   podman run --rm -it \
#       -v "$(pwd)":/home/"$(whoami)"/looni-neutron_builder:z \
#       -v looni-neutron_builder-ccache:/home/"$(whoami)"/.ccache:z \
#       looni-neutron_builder \
#       bash neutron-builder.sh --source proton-wine
#
# Notes:
#   • Podman rootless is strongly recommended (no daemon, SELinux-safe with :z)
#   • Docker works too; drop :z from volume flags if SELinux is not in use
#   • The image is ~5–6 GB; rebuild only when this file changes

ARG BUILD_USER=user
ARG BUILD_UID=1000
ARG BUILD_GID=1000

FROM ubuntu:24.04

ARG BUILD_USER
ARG BUILD_UID
ARG BUILD_GID

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

# ── Add i386 architecture (required for 32-bit Wine libs) ──────────────────
RUN dpkg --add-architecture i386

# ── Package installation ────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \

    # ── Core build toolchain ──────────────────────────────────────────────
    build-essential \
    git \
    python3 \
    python3-pip \
    python3-jinja2 \
    perl \
    flex \
    bison \
    autoconf \
    automake \
    libtool \
    pkg-config \
    cmake \

    # ── Meson + Ninja (DXVK and VKD3D-Proton build system) ────────────────
    meson \
    ninja-build \

    # ── SPIR-V / shader toolchain (DXVK requires glslangValidator) ─────────
    # glslang-tools provides glslangValidator; spirv-tools provides spirv-as/spirv-val.
    # spirv-headers provides the spirv/unified1/spirv.hpp header DXVK checks for.
    # No separate -dev package is needed — headers aren't used at build time here.
    glslang-tools \
    spirv-tools \
    spirv-headers \

    # ── Native x86_64 compilers ────────────────────────────────────────────
    gcc \
    g++ \

    # ── 32-bit cross-compiler (Wine WoW64 stub loader) ─────────────────────
    gcc-i686-linux-gnu \
    g++-i686-linux-gnu \

    # ── MinGW PE cross-compilers (Wine --with-mingw; DXVK; VKD3D) ──────────
    gcc-mingw-w64 \
    g++-mingw-w64 \
    mingw-w64-tools \

    # ── ccache (dramatically speeds up rebuilds) ────────────────────────────
    ccache \

    # ── Rust (used by some Proton components) ───────────────────────────────
    rustc \
    cargo \

    # ── Archive / packaging tools ───────────────────────────────────────────
    tar \
    zstd \
    xz-utils \
    rsync \
    curl \

    # ── Interactive UI helpers ───────────────────────────────────────────────
    fzf \

    # ══════════════════════════════════════════════════════════════════════
    #  Wine / Proton-Wine build dependencies  (64-bit)
    # ══════════════════════════════════════════════════════════════════════

    # Graphics / display
    libx11-dev \
    libxext-dev \
    libxrandr-dev \
    libxcomposite-dev \
    libxinerama-dev \
    libxcursor-dev \
    libxfixes-dev \
    libxi-dev \
    libxrender-dev \
    libxslt1-dev \
    libxml2-dev \
    libwayland-dev \
    wayland-protocols \
    libegl-dev \
    libxkbcommon-dev \
    libxkbregistry-dev \

    # Vulkan (headers are bundled inside libvulkan-dev on Ubuntu 24.04)
    libvulkan-dev \

    # Audio
    libasound2-dev \
    libpulse-dev \

    # GStreamer (Proton uses GStreamer for media playback — required)
    libgstreamer1.0-dev \
    libgstreamer-plugins-base1.0-dev \
    libgstreamer-plugins-good1.0-dev \
    gstreamer1.0-plugins-base \

    # DBus (--with-dbus for Proton)
    libdbus-1-dev \

    # Font / imaging
    libfreetype-dev \
    libfontconfig-dev \
    libpng-dev \
    libjpeg-dev \

    # Input / devices
    libsdl2-dev \
    libudev-dev \
    libusb-1.0-0-dev \

    # OpenCL
    ocl-icd-opencl-dev \
    opencl-headers \

    # Crypto / networking
    libssl-dev \
    libkrb5-dev \
    libgnutls28-dev \

    # Misc Wine deps
    libcups2-dev \
    libpcap-dev \
    libglib2.0-dev \
    libsane-dev \
    libgphoto2-dev \
    libv4l-dev \

    # GLM (header-only math library — VKD3D-Proton)
    libglm-dev \

    # ══════════════════════════════════════════════════════════════════════
    #  Wine / Proton-Wine build dependencies  (32-bit)
    # ══════════════════════════════════════════════════════════════════════
    libx11-dev:i386 \
    libxext-dev:i386 \
    libxrandr-dev:i386 \
    libxcomposite-dev:i386 \
    libxinerama-dev:i386 \
    libxcursor-dev:i386 \
    libxfixes-dev:i386 \
    libxi-dev:i386 \
    libxrender-dev:i386 \
    libvulkan-dev:i386 \
    libwayland-dev:i386 \
    libxkbregistry-dev:i386 \
    libasound2-dev:i386 \
    libpulse-dev:i386 \
    # libgstreamer1.0-dev:i386 and libgstreamer-plugins-base1.0-dev:i386 are
    # intentionally omitted — they declare a hard Conflicts: against their x86_64
    # counterparts and cannot be co-installed on Ubuntu 24.04.  The 32-bit Wine
    # configure only needs the runtime libs + pkg-config paths, which are pulled
    # in as dependencies of the 64-bit dev packages above.
    libdbus-1-dev:i386 \
    libfreetype-dev:i386 \
    libfontconfig-dev:i386 \
    libsdl2-dev:i386 \
    ocl-icd-opencl-dev:i386 \
    libglib2.0-dev:i386 \
    libssl-dev:i386 \

    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ── ntsync kernel header ────────────────────────────────────────────────────
# Ubuntu 24.04's linux-libc-dev predates ntsync (added in Linux 6.14).
# We COPY the header from the build context rather than curling it at build
# time — curl during podman build can fail silently if outbound network is
# restricted in rootless mode.
# Before rebuilding the container, download the header once:
#   curl -fsSL https://raw.githubusercontent.com/torvalds/linux/master/include/uapi/linux/ntsync.h \
#        -o ~/wine-custom/looni-build/looni-neutron_builder/ntsync.h
COPY ntsync.h /usr/include/linux/ntsync.h
# Also copy to the multiarch path — Wine's configure searches
# /usr/include/x86_64-linux-gnu with -I and that's the only path it checks.
# Without this copy the header exists but configure can't find it.
RUN mkdir -p /usr/include/x86_64-linux-gnu/linux \
    && cp /usr/include/linux/ntsync.h \
          /usr/include/x86_64-linux-gnu/linux/ntsync.h
# This ensures files written to bind-mounted volumes are owned by you on the host.
# Ubuntu 24.04 ships with a default "ubuntu" user at UID 1000.  If our target
# UID/GID is already taken by a different user, remove it first so useradd
# can claim the UID cleanly.
RUN _existing_user="$(getent passwd "${BUILD_UID}" 2>/dev/null | cut -d: -f1 || true)" \
    && if [ -n "$_existing_user" ] && [ "$_existing_user" != "${BUILD_USER}" ]; then \
           userdel -r "$_existing_user" 2>/dev/null || true; \
       fi \
    && _existing_group="$(getent group "${BUILD_GID}" 2>/dev/null | cut -d: -f1 || true)" \
    && if [ -n "$_existing_group" ] && [ "$_existing_group" != "${BUILD_USER}" ]; then \
           groupdel "$_existing_group" 2>/dev/null || true; \
       fi \
    && groupadd --gid "${BUILD_GID}" "${BUILD_USER}" 2>/dev/null || true \
    && (getent passwd "${BUILD_USER}" >/dev/null 2>&1 || useradd \
           --uid "${BUILD_UID}" \
           --gid "${BUILD_GID}" \
           --shell /bin/bash \
           --create-home \
           "${BUILD_USER}")

# ── Create persistent ccache directory ─────────────────────────────────────
RUN mkdir -p /home/"${BUILD_USER}"/.ccache \
    && chown "${BUILD_UID}":"${BUILD_GID}" /home/"${BUILD_USER}"/.ccache

# ── Configure ccache by writing the config file directly ───────────────────
# Avoids 'su' and user-resolution issues during the build step.
RUN mkdir -p /home/"${BUILD_USER}"/.config/ccache \
    && printf 'max_size = 20G\n' \
        > /home/"${BUILD_USER}"/.config/ccache/ccache.conf \
    && chown -R "${BUILD_UID}":"${BUILD_GID}" \
        /home/"${BUILD_USER}"/.config

# ── Switch to the build user ─────────────────────────────────────────────────
USER "${BUILD_USER}"
WORKDIR /home/"${BUILD_USER}"/looni-neutron_builder

# ── Trust all directories for git (needed when bind-mounts are owned by root) ─
RUN git config --global --add safe.directory '*'

CMD ["/bin/bash"]
