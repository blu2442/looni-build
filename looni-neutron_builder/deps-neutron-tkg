#!/usr/bin/env bash
# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  looni-neutron_builder  •  deps-neutron-tkg                                ║
# ║  Ubuntu 24.04 (Noble) compatible dependency installer for proton-tkg      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
#
# Deployed by _run_proton_tkg to:
#   <wine-tkg-git>/wine-tkg-scripts/deps
#
# This overrides TKG's stock deps file to handle Ubuntu 24.04's multi-arch
# limitations.  Key differences from the stock file:
#
#  • 32-bit dev packages are NOT installed here — they conflict fatally with
#    their 64-bit counterparts on Ubuntu 24.04.  Instead proton-tkg.cfg sets
#    _NOLIB32="wow64" which builds a WoW64-capable 64-bit Wine that handles
#    32-bit apps at runtime without a separate 32-bit compiler pass.
#
#  • _ci_build="true" is set in proton-tkg.cfg to suppress TKG's interactive
#    "please read issue #773 before continuing" prompt on Ubuntu.
#
#  • deb.sury.org packages are removed if present — they can ship versions
#    that shadow Ubuntu's own packages and break the build.
#
# Sourced by wine-tkg-git/non-makepkg-build.sh when
# _nomakepkg_dep_resolution_distro="debuntu" is set.
# =============================================================================

_install_debuntu_deps() {
    local _pkg_64=(
        # ── Build essentials ──────────────────────────────────────────────────
        gcc g++ make autoconf automake libtool pkg-config bison flex
        schedtool ccache

        # ── MinGW cross-compilers (Windows PE modules) ────────────────────────
        gcc-mingw-w64-i686 g++-mingw-w64-i686
        gcc-mingw-w64-x86-64 g++-mingw-w64-x86-64

        # ── Wine build tools ──────────────────────────────────────────────────
        git perl python3 python3-pip

        # ── Graphics / display ────────────────────────────────────────────────
        libx11-dev libxext-dev libxrandr-dev libxinerama-dev
        libxcomposite-dev libxcursor-dev libxi-dev libxfixes-dev
        libxrender-dev libxt-dev libxmu-dev
        libwayland-dev wayland-protocols libxkbcommon-dev
        libvulkan-dev vulkan-utility-libraries-dev

        # ── Fonts ─────────────────────────────────────────────────────────────
        libfreetype-dev libfontconfig1-dev

        # ── Audio ─────────────────────────────────────────────────────────────
        libasound2-dev libpulse-dev

        # ── Media / GStreamer ─────────────────────────────────────────────────
        libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev

        # ── DBus / desktop integration ────────────────────────────────────────
        libdbus-1-dev libsdl2-dev

        # ── DXVK / VKD3D shader compilation ──────────────────────────────────
        glslang-tools meson ninja-build

        # ── Fonts (needed by Valve's Proton build to compile Liberation Fonts) ─
        fontforge python3-fonttools

        # ── Compression / network ─────────────────────────────────────────────
        zlib1g-dev liblzma-dev libssl-dev libcups2-dev

        # ── Miscellaneous Wine deps ───────────────────────────────────────────
        libxml2-dev libxslt1-dev libjpeg-dev libpng-dev libtiff-dev
        libkrb5-dev libgphoto2-dev libsane-dev libv4l-dev
        libudev-dev libusb-1.0-0-dev
        libpcap-dev
        ocl-icd-opencl-dev
    )

    # ── Remove deb.sury.org packages if present ───────────────────────────────
    # These shadow Ubuntu's own packages and can break MinGW compilation.
    if command -v aptitude >/dev/null 2>&1; then
        local _sury_pkgs
        _sury_pkgs=$(dpkg-query -W -f='${Package} ${Version}\n' 2>/dev/null \
            | grep 'deb\.sury\.org' \
            | awk '{print $1}')
        if [ -n "$_sury_pkgs" ]; then
            msg2 "Removing deb.sury.org packages that conflict with Ubuntu's MinGW stack..."
            # shellcheck disable=SC2086
            aptitude remove -y $_sury_pkgs 2>/dev/null || true
        fi
    fi

    # ── Enable i386 architecture (needed for Wine runtime, not build deps) ────
    # We don't install i386 dev packages — _NOLIB32="wow64" in proton-tkg.cfg
    # handles 32-bit app support at runtime without them.
    if ! dpkg --print-foreign-architectures | grep -q i386; then
        msg2 "Enabling i386 architecture for Wine runtime libraries..."
        sudo dpkg --add-architecture i386
        sudo apt-get update -qq
    fi

    # ── Install 64-bit build deps ─────────────────────────────────────────────
    msg2 "Installing 64-bit build dependencies..."
    # shellcheck disable=SC2068
    if ! sudo apt-get install -y --no-install-recommends ${_pkg_64[@]}; then
        error "64-bit dependency installation failed."
        error "Check the output above and install missing packages manually."
        return 1
    fi

    msg2 "Dependencies installed successfully."
    msg2 "Note: 32-bit dev packages intentionally skipped (using wow64 mode)."

    # ── libpthreads.so symlink fix ────────────────────────────────────────────
    # Valve's Kaldi CMake build has a bug where, when its first pthread detection
    # test fails, it falls back to -lpthreads (with an 's') which does not exist
    # on Linux (the correct name is -lpthread).  GCC 14 / Ubuntu 24.04 triggers
    # this because CMake's libc pthread detection is stricter than before.
    # A symlink from libpthreads.so to libpthread.so satisfies the linker
    # without changing anything else on the system.
    local _pthread_dir
    _pthread_dir="/usr/lib/x86_64-linux-gnu"
    if [ ! -e "${_pthread_dir}/libpthreads.so" ]; then
        msg2 "Creating libpthreads.so symlink for Kaldi CMake compatibility..."
        sudo ln -sf "${_pthread_dir}/libpthread.so" \
                    "${_pthread_dir}/libpthreads.so" \
            && msg2 "  ✓  ${_pthread_dir}/libpthreads.so → libpthread.so" \
            || msg2 "  ⚠  Could not create symlink — run manually: sudo ln -sf ${_pthread_dir}/libpthread.so ${_pthread_dir}/libpthreads.so"
    else
        msg2 "libpthreads.so symlink already present — skipping"
    fi
}

# ── Entry point called by non-makepkg-build.sh ───────────────────────────────
# The stock deps file defines _install_deps_debuntu / _install_deps_64 etc.
# We define the same interface so the caller works unchanged.

_install_deps_debuntu() {
    _install_debuntu_deps
}

# Some TKG versions call this directly
install_deps() {
    _install_debuntu_deps
}
