# ── Build artifacts ───────────────────────────────────────────────────────────
# Generated by looni-wine_builder and looni-neutron_builder during builds.
# These can be many GB — never commit them.
looni-wine_builder/buildz/
looni-wine_builder/src/
looni-neutron_builder/buildz/
looni-neutron_builder/src/

# ── Debug / scratch files ─────────────────────────────────────────────────────
debug-*.txt
*.log

# ── User config ───────────────────────────────────────────────────────────────
# winetoolz user config lives at ~/.config/looni-build/winetoolz.cfg
# The _config file at the project root is a personal leftover — ignore it.
_config
looni-winetoolz/_config

# ── Editor / OS noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*~
*.swp
*.swo
.vscode/
.idea/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
